# Copy to ".env" (see root README). Used when running the bot outside Docker.

# Required — from @BotFather
TELEGRAM_BOT_TOKEN=

# Base URL of the Football Fan API (no trailing slash). In Docker Compose use http://api:8080
API_BASE_URL=http://localhost:8080

# Must match the API process API_INTERNAL_KEY (header X-API-Key)
API_INTERNAL_KEY=

# IANA timezone for match digest formatting (default in code: UTC if unset)
NOTIFY_TZ=America/Sao_Paulo

# Set to debug for per-request API logs (X-API-Key is never logged)
# LOG_LEVEL=debug
