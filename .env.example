# Copy to ".env" in this directory. Docker Compose loads ".env" automatically for
# variable substitution in docker-compose.yaml (do not commit ".env").
#
# For running API or scrapers on the host against a local Postgres, use localhost
# in DATABASE_URL (see README "Local PostgreSQL"). Inside Compose, services use the
# postgres service hostname instead (values are set in docker-compose.yaml).

# Optional: override scraper schedule when using docker compose (see scrappers/README.md)
# SCRAPER_INTERVAL_HOURS=24
# SCRAPER_CRON=0 3 * * *
# LOG_LEVEL=INFO

# pgAdmin (docker compose service pgadmin): http://localhost:5050 — change defaults in production
# PGADMIN_DEFAULT_EMAIL=admin@example.com
# PGADMIN_DEFAULT_PASSWORD=admin
# PGADMIN_PORT=5050
