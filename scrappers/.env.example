# Copy to ".env" in this directory. Load before running:  set -a && source .env && set +a
# (bash). Do not commit ".env".

# Required — same database the API uses (migrations must have been applied once)
DATABASE_URL=postgres://football:football@localhost:5432/football?sslmode=disable

# Optional — see scrappers/README.md
# SCRAPER_CRON=0 3 * * *
# SCRAPER_INTERVAL_HOURS=24
# TICKET_SCRAPER_INTERVAL_MINUTES=30
# TICKET_SCRAPER_ENABLED=true
# LOG_LEVEL=INFO
# SCRAPER_HORIZON_DAYS=45
# SOCCERWAY_URL_BRASILEIRAO_A=
# SOCCERWAY_URL_BRASILEIRAO_B=
