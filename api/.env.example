# Copy to ".env" in this directory. Load before running:  set -a && source .env && set +a
# (bash). Do not commit ".env".

# Required — adjust user, password, host, port, database name to match your Postgres
DATABASE_URL=postgres://football:football@localhost:5432/football?sslmode=disable

# Optional
# HTTP_ADDR=:8080

# Shared secret for POST /users, GET /users/subscriptions, POST /notification-receipts (integrations must send X-API-Key).
# API_INTERNAL_KEY=

# debug — more verbose slog output (e.g. request-scoped diagnostics)
# LOG_LEVEL=debug
